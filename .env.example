# ─────────────────────────────────────────────────────────────
# VINTAGE CLUB — environment configuration
# Copy this file to `.env` and adjust. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- Auth secret (used to sign login sessions / JWT) ---
# Generate a strong one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string

# --- Initial admin account (seeded on first run only) ---
# After first login you can change these from the admin portal.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Store Owner

# --- Store defaults ---
STORE_NAME=Vintage Club

# WhatsApp number that RECEIVES orders (international format, digits only, no +).
# Example for Sri Lanka 077 123 4567 -> 94771234567
# This is only the initial value; the admin can change it in the dashboard.
WHATSAPP_NUMBER=94770000000

# Store currency symbol shown in the UI
CURRENCY=Rs.

# SQLite database file location (relative to project root)
DATABASE_PATH=./data/vintage.db

# Public site URL — used for sitemap.xml, robots.txt, canonical URLs and Open Graph.
# In production set this to your real domain, e.g. https://vintageclub.lk
SITE_URL=http://localhost:3000

# Whether the login session cookie gets the `Secure` flag (HTTPS-only cookie).
# Leave unset: it auto-enables only when SITE_URL is https://. Accessing the
# store over a LAN IP (http://192.168.x.x:3000) needs this OFF or login fails.
# Force it explicitly if needed:  COOKIE_SECURE=true  or  COOKIE_SECURE=false
# COOKIE_SECURE=false
